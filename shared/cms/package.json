{
  "name": "@signature-kit/cms",
  "version": "0.1.0",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./icp-brasil": {
      "types": "./dist/icp-brasil.d.ts",
      "import": "./dist/icp-brasil.js"
    },
    "./sign": {
      "types": "./dist/sign.d.ts",
      "import": "./dist/sign.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@peculiar/asn1-cms": "2.8.0",
    "@peculiar/asn1-ess": "2.8.0",
    "@peculiar/asn1-schema": "2.8.0",
    "@peculiar/asn1-x509": "2.8.0",
    "@signature-kit/asn1": "^0.1.0",
    "asn1js": "3.0.10",
    "effect": "4.0.0-beta.86",
    "pkijs": "3.4.0"
  },
  "nx": {
    "targets": {
      "npm-pack": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm pack --dry-run --json",
          "cwd": "{projectRoot}"
        }
      },
      "npm-publish": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm publish --access public",
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}

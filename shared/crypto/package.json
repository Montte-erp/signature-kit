{
  "name": "@signature-kit/crypto",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./base64": {
      "types": "./dist/base64.d.ts",
      "import": "./dist/base64.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./pem": {
      "types": "./dist/pem.d.ts",
      "import": "./dist/pem.js"
    },
    "./pkcs12": {
      "types": "./dist/pkcs12.d.ts",
      "import": "./dist/pkcs12.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@signature-kit/asn1": "workspace:*",
    "effect": "4.0.0-beta.86"
  }
}

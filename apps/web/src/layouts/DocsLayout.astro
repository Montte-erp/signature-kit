---
import { ChevronRight, Hash } from "@lucide/astro";
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/widgets/Header.astro";
import { docsNavigation, site } from "../config";

interface Props {
  title?: string;
  description?: string;
  group?: string;
  toc?: [string, string][];
}

const {
  title = "Instalação",
  description = "Instale e configure o SignatureKit.",
  group = "comece aqui",
  toc = [],
} = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<BaseLayout title={`${title} | SignatureKit`} description={description}>
  <Header docs sidebarToggle />

  <div class="sw-container grid gap-8 lg:grid-cols-[230px_minmax(0,1fr)] xl:grid-cols-[230px_minmax(0,720px)_200px]">
    <!-- Mobile overlay -->
    <div
      data-sidebar-overlay
      data-open="false"
      class="fixed inset-0 z-40 bg-background/70 opacity-0 backdrop-blur-sm transition data-[open=false]:pointer-events-none data-[open=true]:opacity-100 lg:hidden"
    >
    </div>

    <!-- Sidebar -->
    <aside
      data-sidebar
      data-open="false"
      class="fixed inset-y-0 left-0 z-50 w-72 -translate-x-full overflow-y-auto border-r border-border bg-sidebar px-5 py-6 transition-transform data-[open=true]:translate-x-0 lg:sticky lg:top-14 lg:z-0 lg:h-[calc(100vh-3.5rem)] lg:w-auto lg:translate-x-0 lg:bg-transparent lg:px-0 lg:pr-6 lg:pt-8"
    >
      <div
        class="mb-6 inline-flex items-center gap-2 rounded-md border border-border bg-card px-2.5 py-1 font-mono text-[11px] text-muted-foreground"
      >
        <span class="inline-flex size-1.5 rounded-full bg-primary"></span>
        v{site.version} · beta
      </div>

      <nav aria-label="Navegação da documentação">
        {
          docsNavigation.map((g) => (
            <div class="mb-7">
              <p class="mb-2 px-3 font-mono text-[11px] lowercase tracking-[0.12em] text-muted-foreground/70">
                {g.title}
              </p>
              <div class="space-y-0.5">
                {g.links.map((link) => {
                  const active = path === link.href.replace(/\/$/, "");
                  return (
                    <a
                      class={`block rounded-md px-3 py-1.5 text-sm transition ${active ? "bg-primary/10 font-medium text-foreground" : "text-muted-foreground hover:bg-card hover:text-foreground"}`}
                      href={link.href}
                    >
                      {link.text}
                    </a>
                  );
                })}
              </div>
            </div>
          ))
        }
      </nav>
    </aside>

    <!-- Content -->
    <main class="min-w-0 py-10 lg:py-12">
      <nav class="mb-6 flex items-center gap-1.5 font-mono text-xs lowercase text-muted-foreground" aria-label="Trilha">
        <a href="/docs" class="transition hover:text-foreground">docs</a>
        <ChevronRight class="size-3 opacity-60" />
        <span>{group}</span>
        <ChevronRight class="size-3 opacity-60" />
        <span class="text-foreground">{title}</span>
      </nav>
      <article class="sw-prose">
        <slot />
      </article>
    </main>

    <!-- TOC -->
    <aside class="hidden py-12 xl:block">
      {
        toc.length > 0 && (
          <div class="sticky top-20">
            <p class="mb-3 font-mono text-[11px] lowercase tracking-[0.12em] text-muted-foreground/70">nesta página</p>
            <div class="space-y-0.5 border-l border-border">
              {toc.map(([label, href]) => (
                <a
                  class="toc-link -ml-px flex items-center gap-1.5 border-l border-transparent py-1.5 pl-3 text-xs text-muted-foreground transition hover:text-foreground data-[active=true]:border-primary data-[active=true]:text-foreground"
                  href={href}
                  data-active="false"
                >
                  <Hash class="size-3 opacity-40" />
                  {label}
                </a>
              ))}
            </div>
          </div>
        )
      }
    </aside>
  </div>
</BaseLayout>

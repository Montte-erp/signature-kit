---
import DocsLayout from "../../layouts/DocsLayout.astro";
import DocsActions from "../../components/DocsActions.astro";
import CodePanel from "../../components/CodePanel.astro";
import InstallTabs from "../../components/InstallTabs.astro";

const docusignCode = `import { createDocuSignSignatureRequest } from "@signature-kit/docusign"
import { signatureHttpClientLive } from "@signature-kit/core/http"
import { Effect, Redacted } from "effect"

const request = yield* createDocuSignSignatureRequest(
  {
    baseUrl: process.env.DOCUSIGN_BASE_URL!,
    accountId: process.env.DOCUSIGN_ACCOUNT_ID!,
    accessToken: Redacted.make(process.env.DOCUSIGN_TOKEN ?? ""),
  },
  {
    title: "Contrato de prestação de serviços",
    documents: [{ fileName: "contrato.pdf", mimeType: "application/pdf", content }],
    recipients: [{ name: "Ana Souza", email: "ana@exemplo.com.br" }],
    send: true,
  },
).pipe(Effect.provide(signatureHttpClientLive))`;

const clicksignCode = `import { createClicksignSignatureRequest } from "@signature-kit/clicksign"
import { signatureHttpClientLive } from "@signature-kit/core/http"
import { Effect, Redacted } from "effect"

const request = yield* createClicksignSignatureRequest(
  {
    accessToken: Redacted.make(process.env.CLICKSIGN_TOKEN ?? ""),
    environment: "production",
    locale: "pt-BR",
    autoClose: true,
  },
  {
    title: "Termo de adesão",
    documents: [{ fileName: "termo.pdf", mimeType: "application/pdf", content }],
    recipients: [{ name: "Bruno Lima", email: "bruno@exemplo.com.br", role: "signer" }],
  },
).pipe(Effect.provide(signatureHttpClientLive))`;

const assinafyCode = `import { createAssinafySignatureRequest } from "@signature-kit/assinafy"
import { signatureHttpClientLive } from "@signature-kit/core/http"
import { Effect, Redacted } from "effect"

const request = yield* createAssinafySignatureRequest(
  {
    apiKey: Redacted.make(process.env.ASSINAFY_API_KEY ?? ""),
    environment: "sandbox",
  },
  {
    title: "Contrato",
    documents: [{ fileName: "contrato.pdf", mimeType: "application/pdf", content }],
    recipients: [{ name: "Carla Nunes", email: "carla@example.com" }],
  },
).pipe(Effect.provide(signatureHttpClientLive))`;

const zapSignCode = `import { createZapSignSignatureRequest } from "@signature-kit/zapsign"
import { signatureHttpClientLive } from "@signature-kit/core/http"
import { Effect, Redacted } from "effect"

const request = yield* createZapSignSignatureRequest(
  {
    apiToken: Redacted.make(process.env.ZAPSIGN_API_TOKEN ?? ""),
    environment: "sandbox",
  },
  {
    title: "Contrato",
    documents: [{ fileName: "contrato.pdf", mimeType: "application/pdf", content }],
    recipients: [{ name: "Davi Rocha", email: "davi@example.com" }],
  },
).pipe(Effect.provide(signatureHttpClientLive))`;

const toc: [string, string][] = [
  ["Sem gateway", "#sem-gateway"],
  ["DocuSign", "#docusign"],
  ["Clicksign", "#clicksign"],
  ["Assinafy", "#assinafy"],
  ["ZapSign", "#zapsign"],
  ["Erros tipados", "#erros"],
];
---

<DocsLayout
  title="Signers remotos"
  description="Use DocuSign, Clicksign, Assinafy e ZapSign por funções diretas create*SignatureRequest(...), com SignatureHttpClient injetado via Effect Layer."
  group="provedores"
  toc={toc}
>
  <h1>Signers remotos</h1>
  <DocsActions title="Signers remotos" />

  <h2 id="sem-gateway">Sem gateway</h2>
  <p>
    SignatureKit não tem pacote normalizador de provedores. Cada signer remoto vive em <code>signers/*</code>, expõe sua
    própria função <code>create*SignatureRequest(...)</code> e usa o mesmo <code>SignatureHttpClient</code> de
    <code>@signature-kit/core/http</code>. Isso mantém as opções específicas no pacote certo e evita um dispatcher central.
  </p>
  <InstallTabs spec="@signature-kit/core @signature-kit/docusign @signature-kit/clicksign @signature-kit/assinafy @signature-kit/zapsign" />

  <section class="step" data-step="1">
    <h3 id="docusign">DocuSign</h3>
    <p>Cria envelopes na API REST da DocuSign com bearer token, <code>baseUrl</code> e <code>accountId</code>.</p>
    <CodePanel label="docusign.ts" code={docusignCode} />
  </section>

  <section class="step" data-step="2">
    <h3 id="clicksign">Clicksign</h3>
    <p>Envia um documento por requisição na API v1 da Clicksign; o token é transportado como segredo redigido.</p>
    <CodePanel label="clicksign.ts" code={clicksignCode} />
  </section>

  <section class="step" data-step="3">
    <h3 id="assinafy">Assinafy</h3>
    <p>Cria documento, signer e assignment na API Assinafy usando API key ou access token.</p>
    <CodePanel label="assinafy.ts" code={assinafyCode} />
  </section>

  <section class="step" data-step="4">
    <h3 id="zapsign">ZapSign</h3>
    <p>Cria documento PDF na API ZapSign com token bearer e retorna o primeiro link de assinatura.</p>
    <CodePanel label="zapsign.ts" code={zapSignCode} />
  </section>

  <h2 id="erros">Erros tipados</h2>
  <p>
    Todas as funções retornam <code>Effect.Effect&lt;RemoteSignatureRequest, SignatureKitError, SignatureHttpClient&gt;</code>.
    Falhas de entrada, HTTP e shape de resposta permanecem no canal tipado do Effect com <code>provider</code>,
    <code>operation</code>, <code>schemaName</code> e <code>status</code> quando esses dados existem.
  </p>

  <div class="next-prev">
    <a href="/docs/pdf">← PDF / PAdES</a>
    <a href="/docs/providers/docusign">DocuSign →</a>
  </div>
</DocsLayout>

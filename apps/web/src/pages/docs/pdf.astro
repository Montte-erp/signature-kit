---
import DocsLayout from "../../layouts/DocsLayout.astro";
import DocsActions from "../../components/DocsActions.astro";
import CodePanel from "../../components/CodePanel.astro";
import InstallTabs from "../../components/InstallTabs.astro";

const signCode = `import { signPdf } from "@signature-kit/pdf"
import { a1SignaturesLayer } from "@signature-kit/a1"
import { Effect, Redacted } from "effect"

const program = signPdf({
  pdf,                          // Uint8Array — bytes do PDF original
  reason: "Aprovação do contrato",
  name: "Maria Souza",
  location: "São Paulo, BR",
  signatureLength: 16384,       // bytes reservados para o /Contents do CMS
}).pipe(
  Effect.provide(
    a1SignaturesLayer({
      pfx,                                   // Uint8Array — PKCS#12 (.pfx/.p12)
      password: Redacted.make(process.env.A1_PASSWORD ?? ""),
    }),
  ),
)

const signedPdf: Uint8Array = yield* program  // PDF assinado, política pades-ades`;

const policyCode = `// PdfSignaturePolicy = "pades-ades" | "pades-icp-brasil"
// Default da assinatura quando policy é omitido: "pades-ades"

// Busca automática da política AD-RB (sem icpBrasil explícito)
const auto = signPdf({
  pdf,
  policy: "pades-icp-brasil",
  policyTimeoutMillis: 10_000,   // limite da busca remota da PA
}).pipe(Effect.provide(layer))

// Política ICP-Brasil explícita — você fornece os identificadores
const explicit = signPdf({
  pdf,
  policy: "pades-icp-brasil",
  hashAlgorithm: "sha256",       // apenas "sha256" ou "sha512"
  icpBrasil: {
    policyOid: "2.16.76.1.7.1.11.1.1",
    policyHash: new Uint8Array(32),
    policyHashAlgorithm: "sha256",
    policyUri: "http://politicas.icpbrasil.gov.br/PA_PAdES_AD_RB_v1_1.der",
  },
}).pipe(Effect.provide(layer))`;

const verifyCode = `import { verifyPdf } from "@signature-kit/pdf"
import { Effect } from "effect"

// verifyPdf NÃO requer o serviço Signatures — não há .pipe(Effect.provide(...))
const result = yield* verifyPdf({ pdf: signedPdf })

result.valid             // boolean — integridade do CMS sobre o byteRange
result.chainValid        // boolean — cadeia do signatário verificada
result.signatureCount    // number  — assinaturas encontradas no PDF
result.byteRange         // [number, number, number, number]
result.signerSerialNumber // string | null — serial do certificado signatário`;

const toc: [string, string][] = [
  ["Instale o pacote", "#instalar"],
  ["Assinar um PDF", "#assinar"],
  ["Política PAdES ICP-Brasil", "#icp-brasil"],
  ["Verificar com verifyPdf", "#verificar"],
  ["Erros que você pode ver", "#erros"],
];
---

<DocsLayout
  title="PDF / PAdES"
  description="Assine PDFs com PAdES via signPdf, aplique a política ICP-Brasil (AD-RB) e verifique a assinatura com verifyPdf — tudo sobre a fronteira Signatures."
  group="formatos"
  toc={toc}
>
  <h1>PDF / PAdES</h1>
  <DocsActions title="PDF / PAdES" />

  <p>
    <strong>O que você vai fazer:</strong> assinar bytes de PDF no padrão PAdES com <code>signPdf</code>, escolher entre a
    política <code>"pades-ades"</code> e a <code>"pades-icp-brasil"</code> (AD-RB) e conferir o resultado com
    <code>verifyPdf</code>. A potência de assinatura vem da fronteira <code>Signatures</code>, fornecida por
    <code>a1SignaturesLayer</code> — o módulo de PDF cuida só da mutação do documento.
  </p>

  <section class="step" data-step="1">
    <h3 id="instalar">Instale o pacote</h3>
    <p>O módulo de PDF é <code>@signature-kit/pdf</code>. Ele consome a fronteira fornecida pelo assinador A1.</p>
    <InstallTabs spec="@signature-kit/pdf" />
    <p class="aside">
      <strong>Nota:</strong> <code>signPdf</code> exige o serviço <code>Signatures</code> no canal de requisitos;
      <code>verifyPdf</code> não exige.
    </p>
  </section>

  <section class="step" data-step="2">
    <h3 id="assinar">Assinar um PDF</h3>
    <p>
      <code>signPdf(input: PdfSigningRequest)</code> devolve um <code>Effect&lt;Uint8Array, PdfError | CmsError |
      SignatureKitError, Signatures&gt;</code> — os bytes do PDF assinado. Forneça <code>Signatures</code> com
      <code>Effect.provide(a1SignaturesLayer(...))</code>.
    </p>
    <CodePanel label="assinar-pdf.ts" code={signCode} />
    <p>
      <code>signatureLength</code> reserva o espaço (em bytes) do campo <code>/Contents</code> que recebe o CMS — um valor
      curto demais faz a assinatura falhar. Sem <code>reason</code> e <code>name</code>, os defaults são
      <code>"Digital signature"</code> e <code>"SignatureKit signer"</code>. Os demais campos opcionais incluem
      <code>contactInfo</code>, <code>location</code>, <code>signingTime</code>, <code>timestamp</code> e
      <code>appearance</code>.
    </p>
    <p class="aside">
      <strong>Atenção:</strong> <code>hashAlgorithm</code> aceita apenas <code>"sha256"</code> (→ <code>rsa-sha256</code>)
      ou <code>"sha512"</code> (→ <code>rsa-sha512</code>). Valores como <code>sha1</code> ou <code>sha384</code> falham com
      <code>pdf.SIGN_FAILED</code>.
    </p>
  </section>

  <section class="step" data-step="3">
    <h3 id="icp-brasil">Política PAdES ICP-Brasil</h3>
    <p>
      <code>PdfSignaturePolicy</code> tem exatamente dois valores: <code>"pades-ades"</code> (default) e
      <code>"pades-icp-brasil"</code>. Ao escolher <code>"pades-icp-brasil"</code> <strong>sem</strong> o campo
      <code>icpBrasil</code>, o módulo busca automaticamente a Política de Assinatura AD-RB — controle esse fetch remoto com
      <code>policyTimeoutMillis</code>. Para evitar a rede, passe o objeto <code>icpBrasil</code> explícito.
    </p>
    <CodePanel label="politica-icp-brasil.ts" code={policyCode} />
    <p>
      O objeto explícito carrega <code>policyOid</code>, <code>policyHash</code>, <code>policyHashAlgorithm</code> e
      <code>policyUri</code> — os mesmos identificadores da PA AD-RB que a busca automática traria, agora fixados no seu
      código.
    </p>
    <p class="aside">
      <strong>Dica:</strong> mantenha <code>policyHashAlgorithm</code> coerente com o <code>hashAlgorithm</code> da
      assinatura — use <code>"sha256"</code> ou <code>"sha512"</code> nos dois.
    </p>
  </section>

  <section class="step" data-step="4">
    <h3 id="verificar">Verificar com verifyPdf</h3>
    <p>
      <code>verifyPdf(input: PdfVerificationRequest)</code> devolve um <code>Effect&lt;PdfVerificationResult, PdfError |
      CmsError&gt;</code> — <strong>sem</strong> requisito de <code>Signatures</code>, então não há
      <code>Effect.provide(...)</code> aqui. Opcionalmente passe <code>trustedRoots</code> (lista de
      <code>Uint8Array</code>) para validar a cadeia contra raízes próprias.
    </p>
    <CodePanel label="verificar-pdf.ts" code={verifyCode} />
    <p>
      <code>byteRange</code> é a quádrupla <code>[number, number, number, number]</code> coberta pela assinatura, e
      <code>signerSerialNumber</code> é o serial do certificado signatário ou <code>null</code> quando não há assinatura.
    </p>
  </section>

  <h2 id="erros">Erros que você pode ver</h2>
  <p>
    Assinatura e verificação de PDF falham com códigos da família <code>pdf.*</code> (<code>PdfError</code>); falhas do
    assinador A1 que provê o <code>Signatures</code> chegam como <code>signature-kit.*</code>.
  </p>
  <ul>
    <li>
      <a href="/docs/errors#familias"><code>pdf.SIGN_FAILED</code></a> — <code>hashAlgorithm</code> não suportado (ex.:
      <code>sha1</code>/<code>sha384</code>).
    </li>
    <li>
      <a href="/docs/errors#familias"><code>pdf.SIGNATURE_TOO_LARGE</code></a> — o CMS excedeu o espaço reservado; aumente
      <code>signatureLength</code>.
    </li>
    <li>
      <a href="/docs/errors#familias"><code>pdf.INVALID_PDF</code></a> — os bytes não formam um PDF íntegro para assinar ou
      verificar.
    </li>
    <li>
      <a href="/docs/errors#err-WRONG_PASSWORD"><code>signature-kit.WRONG_PASSWORD</code></a> — senha do A1 incorreta ao prover
      o serviço de assinaturas.
    </li>
  </ul>

  <div class="next-prev">
    <a href="/docs/xml">← XML-DSig</a>
    <a href="/docs/providers">Gateway →</a>
  </div>
</DocsLayout>

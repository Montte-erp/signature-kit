---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import DocsActions from "../../../components/DocsActions.astro";
import CodePanel from "../../../components/CodePanel.astro";
import InstallTabs from "../../../components/InstallTabs.astro";

const clicksignCode = `import { createClicksignSignatureRequest } from "@signature-kit/clicksign"
import { signatureHttpClientLive } from "@signature-kit/core/http"
import { Effect, Redacted } from "effect"

const request = yield* createClicksignSignatureRequest(
  {
    accessToken: Redacted.make(process.env.CLICKSIGN_TOKEN ?? ""),
    environment: "sandbox",
    locale: "pt-BR",
    autoClose: true,
  },
  {
    title: "Termo de adesão",
    message: "Assine para continuar.",
    documents: [{ fileName: "termo.pdf", mimeType: "application/pdf", content: pdfBytes }],
    recipients: [{ name: "Bruno Lima", email: "bruno@example.com", role: "signer" }],
  },
).pipe(Effect.provide(signatureHttpClientLive))

// request.provider === "clicksign"`;

const toc: [string, string][] = [
  ["Instalar", "#instalar"],
  ["Criar documento", "#criar"],
  ["Limite da API", "#limite"],
  ["Erros", "#erros"],
];
---

<DocsLayout
  title="Clicksign"
  description="Crie solicitações Clicksign com createClicksignSignatureRequest(...), sem gateway normalizador."
  group="provedores"
  toc={toc}
>
  <h1>Clicksign</h1>
  <DocsActions title="Clicksign" />

  <section class="step" data-step="1">
    <h2 id="instalar">Instalar</h2>
    <p>Clicksign é um signer remoto direto sobre a API v1.</p>
    <InstallTabs spec="@signature-kit/core @signature-kit/clicksign" />
  </section>

  <section class="step" data-step="2">
    <h2 id="criar">Criar documento</h2>
    <p>
      A função cria o documento, cria o signer e opcionalmente notifica por e-mail. O token fica em
      <code>Redacted</code> até o boundary HTTP.
    </p>
    <CodePanel label="clicksign.ts" code={clicksignCode} />
  </section>

  <h2 id="limite">Limite da API</h2>
  <p>
    A implementação atual aceita um documento por requisição, seguindo o fluxo v1 da Clicksign. Requisições com múltiplos
    documentos falham no canal tipado com <code>signature-kit.UNSUPPORTED_OPERATION</code>.
  </p>

  <h2 id="erros">Erros</h2>
  <p>
    Entrada inválida, HTTP remoto e response shape falham como <code>SignatureKitError</code>, com
    <code>provider: "clicksign"</code>.
  </p>

  <div class="next-prev">
    <a href="/docs/providers/docusign">← DocuSign</a>
    <a href="/docs/providers/assinafy">Assinafy →</a>
  </div>
</DocsLayout>

---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import DocsActions from "../../../components/DocsActions.astro";
import CodePanel from "../../../components/CodePanel.astro";
import InstallTabs from "../../../components/InstallTabs.astro";

const zapSignCode = `import { createZapSignSignatureRequest } from "@signature-kit/zapsign"
import { signatureHttpClientLive } from "@signature-kit/core/http"
import { Effect, Redacted } from "effect"

const request = yield* createZapSignSignatureRequest(
  {
    apiToken: Redacted.make(process.env.ZAPSIGN_API_TOKEN ?? ""),
    environment: "sandbox",
    locale: "pt-br",
  },
  {
    title: "Contrato",
    message: "Assine para concluir.",
    documents: [{ fileName: "contrato.pdf", mimeType: "application/pdf", content: pdfBytes }],
    recipients: [{ name: "Davi Rocha", email: "davi@example.com", role: "signer" }],
  },
).pipe(Effect.provide(signatureHttpClientLive))

// request.provider === "zapsign"
// request.signingUrl contém o primeiro link de assinatura retornado pela ZapSign`;

const toc: [string, string][] = [
  ["Instalar", "#instalar"],
  ["Criar documento", "#criar"],
  ["Limite da API", "#limite"],
  ["Erros", "#erros"],
];
---

<DocsLayout
  title="ZapSign"
  description="Crie documentos ZapSign com createZapSignSignatureRequest(...), API token Redacted e o endpoint REST oficial."
  group="provedores"
  toc={toc}
>
  <h1>ZapSign</h1>
  <DocsActions title="ZapSign" />

  <section class="step" data-step="1">
    <h2 id="instalar">Instalar</h2>
    <p>ZapSign é um signer remoto direto sobre <code>POST /api/v1/docs/</code>, sem gateway intermediário.</p>
    <InstallTabs spec="@signature-kit/core @signature-kit/zapsign" />
  </section>

  <section class="step" data-step="2">
    <h2 id="criar">Criar documento</h2>
    <p>
      A função envia <code>base64_pdf</code>, signatários e autenticação <code>Authorization: Bearer</code>. O retorno normaliza
      <code>token</code>, <code>status</code> e o primeiro <code>sign_url</code> em <code>RemoteSignatureRequest</code>.
    </p>
    <CodePanel label="zapsign.ts" code={zapSignCode} />
  </section>

  <h2 id="limite">Limite da API</h2>
  <p>
    A implementação atual aceita um PDF por requisição, alinhada ao fluxo documentado de upload da ZapSign. Múltiplos
    documentos ou outro MIME falham como <code>signature-kit.UNSUPPORTED_OPERATION</code>.
  </p>

  <h2 id="erros">Erros</h2>
  <p>
    Falhas de entrada, HTTP e response shape usam <code>SignatureKitError</code>, com <code>provider: "zapsign"</code> e metadados
    estruturados quando disponíveis.
  </p>

  <div class="next-prev">
    <a href="/docs/providers/assinafy">← Assinafy</a>
    <span></span>
  </div>
</DocsLayout>

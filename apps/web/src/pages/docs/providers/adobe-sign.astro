---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import DocsActions from "../../../components/DocsActions.astro";
import CodePanel from "../../../components/CodePanel.astro";
import InstallTabs from "../../../components/InstallTabs.astro";

const providerCode = `import { adobeSign } from "@signature-kit/adobe-sign"
import { Redacted } from "effect"

// adobeSign aceita exatamente duas chaves: baseUrl e accessToken.
// O access token é embrulhado em Redacted para não vazar em logs.
const provider = adobeSign({
  baseUrl: "https://api.na1.adobesign.com/api/rest/v6",
  accessToken: Redacted.make(process.env.ADOBE_SIGN_ACCESS_TOKEN!),
})`;

const gatewayCode = `import { createSignatureGateway, createFetchHttpClient } from "@signature-kit/signature-gateway"
import { adobeSign } from "@signature-kit/adobe-sign"
import { Redacted } from "effect"

// O adapter retornado por adobeSign tem id "adobe-sign".
// O gateway despacha por adapter.id === input.provider.
const gateway = createSignatureGateway({
  providers: [
    adobeSign({
      baseUrl: "https://api.na1.adobesign.com/api/rest/v6",
      accessToken: Redacted.make(process.env.ADOBE_SIGN_ACCESS_TOKEN!),
    }),
  ],
  http: createFetchHttpClient(),
})`;

const requestCode = `import { Effect } from "effect"

// provider: "adobe-sign" seleciona o adapter registrado no gateway.
const program = gateway.createSignatureRequest({
  provider: "adobe-sign",
  title: "Contrato de prestação de serviços",
  subject: "Assinatura do contrato 2026/0042",
  message: "Por favor, revise e assine o documento anexo.",
  documents: [
    {
      fileName: "contrato.pdf",
      mimeType: "application/pdf",
      content: pdfBytes, // Uint8Array
    },
  ],
  recipients: [
    { name: "Ana Souza", email: "ana@example.com", role: "signer", routingOrder: 1 },
    { name: "Carlos Lima", email: "carlos@example.com", role: "approver", routingOrder: 2 },
  ],
  send: true,
})

// RemoteSignatureRequest: { provider, id, state, providerStatus?, signingUrl?, detailsUrl? }
const request = await Effect.runPromise(program)
//    request.provider === "adobe-sign"
//    request.state    === "sent" (send: true) | "draft" caso contrário`;

const errorCode = `import { Effect } from "effect"

const handled = gateway
  .createSignatureRequest({
    provider: "adobe-sign",
    title: "Contrato",
    documents: [{ fileName: "contrato.pdf", mimeType: "application/pdf", content: pdfBytes }],
    recipients: [{ name: "Ana Souza", email: "ana@example.com", role: "signer" }],
    send: true,
  })
  .pipe(
    Effect.catchTag("SignatureProviderError", (error) => {
      // error.code: signature_provider.HTTP | INVALID_INPUT | RESPONSE_SHAPE | UNSUPPORTED_OPERATION
      switch (error.code) {
        case "signature_provider.HTTP":
          return Effect.fail(error) // falha no /transientDocuments ou POST /agreements
        case "signature_provider.RESPONSE_SHAPE":
          return Effect.fail(error) // payload da Adobe Sign fora do formato esperado
        default:
          return Effect.fail(error)
      }
    }),
  )`;

const toc: [string, string][] = [
  ["Instalar", "#instalar"],
  ["Configurar o provedor", "#configurar"],
  ["Registrar no gateway", "#gateway"],
  ["Fluxo de upload", "#fluxo-upload"],
  ["Tratar falhas do provedor", "#falhas"],
];
---
<DocsLayout
  title="Adobe Sign"
  description="Configure o provedor Adobe Sign do SignatureKit: autenticação bearer, upload em /transientDocuments e criação de acordos via POST /agreements pelo signature gateway."
  group="provedores"
  toc={toc}
>
  <h1>Adobe Sign</h1>
  <DocsActions title="Adobe Sign" />

  <p>
    <strong>O que você vai fazer:</strong> instalar <code>@signature-kit/adobe-sign</code>, construir o adapter com
    <code>adobeSign(...)</code>, registrá-lo no <code>createSignatureGateway</code> e enviar um documento para
    assinatura. O adapter expõe o id <code>"adobe-sign"</code>; o gateway despacha cada requisição comparando
    <code>adapter.id === input.provider</code>.
  </p>

  <p class="aside">
    <strong>Nota:</strong> a Adobe Sign autentica por bearer. O documento é primeiro enviado a
    <code>/transientDocuments</code> e o id retornado é usado no <code>POST /agreements</code> que cria o acordo.
    O adapter executa essas duas chamadas internamente — você só fornece os bytes em <code>documents[].content</code>.
  </p>

  <section class="step" data-step="1">
    <h3 id="instalar">Instalar</h3>
    <p>
      Instale o pacote do provedor junto do <code>@signature-kit/signature-gateway</code>, que orquestra a requisição
      remota e o cliente HTTP.
    </p>
    <InstallTabs spec="@signature-kit/adobe-sign @signature-kit/signature-gateway" />
  </section>

  <section class="step" data-step="2">
    <h3 id="configurar">Configurar o provedor</h3>
    <p>
      <code>adobeSign</code> aceita exatamente duas chaves: <code>baseUrl</code> e <code>accessToken</code>. O token é
      embrulhado com <code>Redacted.make</code> (importado de <code>effect</code>) para não aparecer em logs nem em
      mensagens de erro. A autenticação é feita por header bearer com esse token.
    </p>
    <CodePanel label="adobe-sign.ts" code={providerCode} />
    <p class="aside">
      <strong>Atenção:</strong> o <code>baseUrl</code> deve apontar para o shard correto da sua conta Adobe Sign
      (por exemplo <code>na1</code>, <code>eu1</code>). Não há chave <code>accountId</code> aqui — diferente do
      provedor DocuSign, a Adobe Sign resolve a conta a partir do próprio token.
    </p>
  </section>

  <section class="step" data-step="3">
    <h3 id="gateway">Registrar no gateway</h3>
    <p>
      Passe o adapter no array <code>providers</code> de <code>createSignatureGateway</code>. Se você omitir
      <code>http</code>, o gateway usa <code>createFetchHttpClient()</code> automaticamente; aqui ele é informado de
      forma explícita.
    </p>
    <CodePanel label="gateway.ts" code={gatewayCode} />
    <p class="aside">
      <strong>Dica:</strong> registre vários adapters no mesmo gateway (DocuSign, Dropbox Sign, Clicksign) e selecione
      cada um por <code>provider</code> na hora da requisição. Sem adapter para o id solicitado, o gateway falha com
      <code>signature_provider.UNSUPPORTED_OPERATION</code>.
    </p>
  </section>

  <section class="step" data-step="4">
    <h3 id="fluxo-upload">Fluxo de upload</h3>
    <p>
      Chame <code>createSignatureRequest</code> com <code>provider: "adobe-sign"</code>. Cada item de
      <code>documents</code> carrega <code>fileName</code>, <code>mimeType</code> e <code>content</code>
      (<code>Uint8Array</code>). O adapter envia o conteúdo a <code>/transientDocuments</code> e usa o id resultante no
      <code>POST /agreements</code>. Com <code>send: true</code>, o acordo já sai com estado <code>"sent"</code>.
    </p>
    <CodePanel label="criar-acordo.ts" code={requestCode} />
    <p>
      O retorno é um <code>RemoteSignatureRequest</code> com os campos <code>provider</code>, <code>id</code>,
      <code>state</code> (<code>"draft"</code> ou <code>"sent"</code>) e, quando a Adobe Sign os fornece,
      <code>providerStatus</code>, <code>signingUrl</code> e <code>detailsUrl</code>. O campo
      <code>recipients[].role</code> aceita valores como <code>"signer"</code> ou <code>"approver"</code>; use
      <code>routingOrder</code> para definir a ordem de roteamento.
    </p>
  </section>

  <section class="step" data-step="5">
    <h3 id="falhas">Tratar falhas do provedor</h3>
    <p>
      Toda falha do gateway é um <code>SignatureProviderError</code> tipado. Use <code>Effect.catchTag</code> para
      ramificar por <code>error.code</code>. Falhas de rede no <code>/transientDocuments</code> ou no
      <code>POST /agreements</code> chegam como <code>signature_provider.HTTP</code>; payloads inesperados da Adobe Sign
      viram <code>signature_provider.RESPONSE_SHAPE</code>.
    </p>
    <CodePanel label="tratar-falhas.ts" code={errorCode} />
    <ul>
      <li>
        <code>signature_provider.HTTP</code> — falha de transporte ou resposta de erro da API Adobe Sign.
      </li>
      <li>
        <code>signature_provider.INVALID_INPUT</code> — entrada inválida em <code>SignatureGatewayRequestInput</code>
        (por exemplo documentos ou destinatários ausentes).
      </li>
      <li>
        <code>signature_provider.RESPONSE_SHAPE</code> — corpo da resposta da Adobe Sign fora do formato esperado.
      </li>
      <li>
        <code>signature_provider.UNSUPPORTED_OPERATION</code> — nenhum adapter registrado para o
        <code>provider</code> informado.
      </li>
    </ul>
  </section>

  <div class="next-prev">
    <a href="/docs/providers/dropbox-sign">← Dropbox Sign</a>
    <a href="/docs/providers/clicksign">Clicksign →</a>
  </div>
</DocsLayout>

---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import DocsActions from "../../../components/DocsActions.astro";
import CodePanel from "../../../components/CodePanel.astro";
import InstallTabs from "../../../components/InstallTabs.astro";

const docusignCode = `import { createDocuSignSignatureRequest } from "@signature-kit/docusign"
import { signatureHttpClientLive } from "@signature-kit/core/http"
import { Effect, Redacted } from "effect"

const request = yield* createDocuSignSignatureRequest(
  {
    baseUrl: "https://demo.docusign.net/restapi",
    accountId: process.env.DOCUSIGN_ACCOUNT_ID!,
    accessToken: Redacted.make(process.env.DOCUSIGN_TOKEN ?? ""),
  },
  {
    title: "Contrato de prestação de serviços",
    subject: "Assinatura do contrato 2026/0042",
    message: "Por favor, revise e assine o documento anexo.",
    documents: [{ fileName: "contrato.pdf", mimeType: "application/pdf", content: pdfBytes }],
    recipients: [{ name: "Ana Souza", email: "ana@example.com", role: "signer" }],
    send: true,
  },
).pipe(Effect.provide(signatureHttpClientLive))

// request.provider === "docusign"
// request.state    === "sent" | "draft"`;

const providerLayerCode = `import * as DocuSign from "@signature-kit/docusign"
import { Redacted } from "effect"

export const providers = DocuSign.providers({
  baseUrl: "https://demo.docusign.net/restapi",
  accountId: process.env.DOCUSIGN_ACCOUNT_ID!,
  accessToken: Redacted.make(process.env.DOCUSIGN_TOKEN ?? ""),
})`;

const toc: [string, string][] = [
  ["Instalar", "#instalar"],
  ["Criar envelope", "#criar"],
  ["Alchemy", "#alchemy"],
  ["Erros", "#erros"],
];
---

<DocsLayout
  title="DocuSign"
  description="Crie envelopes DocuSign com createDocuSignSignatureRequest(...), SignatureHttpClient e erros tipados do SignatureKit."
  group="provedores"
  toc={toc}
>
  <h1>DocuSign</h1>
  <DocsActions title="DocuSign" />

  <section class="step" data-step="1">
    <h2 id="instalar">Instalar</h2>
    <p>DocuSign é um signer remoto direto. Não há gateway intermediário.</p>
    <InstallTabs spec="@signature-kit/core @signature-kit/docusign" />
  </section>

  <section class="step" data-step="2">
    <h2 id="criar">Criar envelope</h2>
    <p>
      Passe as credenciais DocuSign e a requisição normalizada. O pacote monta o payload de envelope e chama
      <code>/v2.1/accounts/{`{accountId}`}/envelopes</code>.
    </p>
    <CodePanel label="docusign.ts" code={docusignCode} />
  </section>

  <section class="step" data-step="3">
    <h2 id="alchemy">Alchemy</h2>
    <p>Para stacks Alchemy, o pacote também exporta <code>providers(options)</code> como layer de providers.</p>
    <CodePanel label="alchemy.ts" code={providerLayerCode} />
  </section>

  <h2 id="erros">Erros</h2>
  <p>
    Entrada inválida, HTTP remoto e response shape falham como <code>SignatureKitError</code>, com
    <code>provider: "docusign"</code> e metadados estruturados.
  </p>

  <div class="next-prev">
    <a href="/docs/providers">← Signers remotos</a>
    <a href="/docs/providers/clicksign">Clicksign →</a>
  </div>
</DocsLayout>

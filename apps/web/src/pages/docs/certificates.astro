---
import DocsLayout from "../../layouts/DocsLayout.astro";
import DocsActions from "../../components/DocsActions.astro";
import CodePanel from "../../components/CodePanel.astro";
import InstallTabs from "../../components/InstallTabs.astro";

const identityTypeCode = `// retorno de certificates.inspect()
type SignerIdentity = {
  subject: string
  issuer: string
  serialNumber: string
  thumbprint: string
  validFrom: Date
  validTo: Date
  document?: string   // CPF (e-CPF) ou CNPJ (e-CNPJ), quando reconhecido
}`;

const inspectCode = `const signatureKit = yield* program

const identity = yield* signatureKit.certificates.inspect()

console.log(identity.subject)       // titular do certificado
console.log(identity.issuer)        // AC emissora (cadeia ICP-Brasil)
console.log(identity.serialNumber)  // número de série
console.log(identity.thumbprint)    // impressão digital
console.log(identity.validFrom, identity.validTo)

// e-CPF -> CPF; e-CNPJ -> CNPJ; ausente se o OID não for reconhecido
if (identity.document !== undefined) {
  console.log("documento:", identity.document)
}`;

const certificateTypeCode = `// retorno de certificates.get()
type Certificate = {
  serialNumber: string
  subject: string
  issuer: string
  validity: { notBefore: Date; notAfter: Date }
  fingerprint: string
  subjectAltName: string[]
  isValid: boolean
  brazilian: { /* CPF/CNPJ e demais campos ICP-Brasil */ }
  certPem: string
  certificateDer: Uint8Array
  publicKeyDer: Uint8Array
  privateKeyPem: Redacted<string>   // segredo — não imprima
}`;

const getCode = `import { Redacted } from "effect"

const cert = yield* signatureKit.certificates.get()

console.log(cert.isValid)        // boolean já calculado pela cadeia
console.log(cert.fingerprint)    // impressão digital do DER
console.log(cert.subjectAltName) // SANs do certificado
console.log(cert.brazilian)      // campos ICP-Brasil extraídos

// a chave privada é Redacted: não aparece em logs nem em JSON.stringify
const pem = Redacted.value(cert.privateKeyPem) // só na fronteira de uso`;

const validityCode = `import { toSignerIdentity, isCertificateValid, daysUntilExpiry } from "@signature-kit/x509"
import { Effect } from "effect"

// cert: Certificate vindo de signatureKit.certificates.get()
const cert = yield* signatureKit.certificates.get()

// identidade derivada do certificado (mesma forma de inspect())
const identity = toSignerIdentity(cert)
// identity.document é preenchido pelos OIDs ICP-Brasil:
//   2.16.76.1.3.1 -> e-CPF   (document = CPF)
//   2.16.76.1.3.3 -> e-CNPJ  (document = CNPJ)

// validade temporal e janela de expiração
const valid = isCertificateValid(cert)   // boolean
const dias = daysUntilExpiry(cert)       // number

if (!valid) {
  yield* Effect.logWarning("certificado fora da validade")
} else if (dias < 30) {
  yield* Effect.logWarning(\`certificado expira em \${dias} dia(s)\`)
}`;

const toc: [string, string][] = [
  ["Ler a identidade", "#identidade"],
  ["O tipo SignerIdentity", "#tipo-identity"],
  ["Inspecionar o certificado", "#inspecionar"],
  ["O tipo Certificate", "#tipo-certificate"],
  ["Validade e ICP-Brasil", "#validade"],
  ["Erros que você pode ver", "#erros"],
];
---

<DocsLayout
  title="Certificados A1"
  description="Leia a identidade do titular de um certificado A1 (e-CPF / e-CNPJ), inspecione o certificado completo e verifique validade e campos ICP-Brasil."
  group="conceitos"
  toc={toc}
>
  <h1>Certificados A1</h1>
  <DocsActions title="Certificados A1" />

  <p>
    <strong>O que você vai fazer:</strong> ler a identidade do titular de um certificado A1 (e-CPF ou e-CNPJ), inspecionar
    o certificado completo e checar validade e campos ICP-Brasil. Um A1 é um arquivo PKCS#12 (<code>.pfx</code>/<code>.p12</code>)
    carregado por <code>@signature-kit/a1</code>; a execução expõe duas leituras independentes do material assinante.
  </p>

  <section class="step" data-step="1">
    <h3 id="identidade">Ler a identidade</h3>
    <p>
      <code>certificates.inspect()</code> devolve um <code>Effect&lt;SignerIdentity, SignatureKitError&gt;</code> com os campos
      essenciais do titular. É a leitura barata: subject, issuer, série, impressão digital, janela de validade e o
      <code>document</code> opcional.
    </p>
    <CodePanel label="ler-identidade.ts" code={inspectCode} />
    <p class="aside">
      <strong>Nota:</strong> <code>document</code> só vem preenchido quando o certificado carrega um OID ICP-Brasil
      reconhecido (e-CPF ou e-CNPJ). Para outros perfis o campo fica ausente — sempre teste <code>!== undefined</code>.
    </p>
  </section>

  <section class="step" data-step="2">
    <h3 id="tipo-identity">O tipo SignerIdentity</h3>
    <p>
      A forma exata do retorno de <code>inspect</code>. <code>validFrom</code> e <code>validTo</code> são <code>Date</code>;
      <code>document</code> é o único campo opcional.
    </p>
    <CodePanel label="signer-identity.ts" code={identityTypeCode} />
  </section>

  <section class="step" data-step="3">
    <h3 id="inspecionar">Inspecionar o certificado</h3>
    <p>
      Quando você precisa de mais do que a identidade, <code>certificates.get()</code> devolve um
      <code>Effect&lt;Certificate, SignatureKitError&gt;</code> com o certificado inteiro: PEM, DER, chave pública, validade
      pré-calculada (<code>isValid</code>), SANs e o bloco <code>brazilian</code> com os campos ICP-Brasil.
    </p>
    <p class="aside">
      <strong>Atenção:</strong> o acessor é <code>certificates.get()</code> — não <code>certificate()</code>. O campo
      <code>privateKeyPem</code> é <code>Redacted&lt;string&gt;</code>: ele não aparece em logs, em <code>console.log</code>
      nem em <code>JSON.stringify</code>. Para obter o PEM você precisa, explicitamente, de <code>Redacted.value(...)</code>,
      e só na fronteira onde a chave é realmente consumida.
    </p>
    <CodePanel label="inspecionar.ts" code={getCode} />
  </section>

  <section class="step" data-step="4">
    <h3 id="tipo-certificate">O tipo Certificate</h3>
    <p>
      A forma completa do retorno de <code>get</code>. Note os três encodings do certificado (<code>certPem</code>,
      <code>certificateDer</code>, <code>publicKeyDer</code>) e a chave privada protegida por <code>Redacted</code>.
    </p>
    <CodePanel label="certificate.ts" code={certificateTypeCode} />
  </section>

  <section class="step" data-step="5">
    <h3 id="validade">Validade e ICP-Brasil</h3>
    <p>Instale o pacote de baixo nível para trabalhar diretamente com o X.509:</p>
    <InstallTabs spec="@signature-kit/x509" class="mb-4" />
    <p>
      <code>@signature-kit/x509</code> expõe utilitários puros sobre o certificado:
      <code>toSignerIdentity(cert)</code> reduz um <code>Certificate</code> para a mesma <code>SignerIdentity</code> de
      <code>inspect</code>; <code>isCertificateValid(cert)</code> retorna um <code>boolean</code> e
      <code>daysUntilExpiry(cert)</code>, um <code>number</code>. Para bytes DER crus, <code>parseX509(der)</code> devolve
      um <code>X509Info</code>.
    </p>
    <CodePanel label="validade.ts" code={validityCode} />
    <p class="aside">
      <strong>Dica:</strong> os OIDs ICP-Brasil populam o campo <code>document</code>:
      <code>2.16.76.1.3.1</code> identifica o e-CPF (o documento é o CPF do titular) e <code>2.16.76.1.3.3</code>
      identifica o e-CNPJ (o documento é o CNPJ). A extração desses campos é feita por
      <code>extractBrazilianFields</code> internamente e já aparece pronta em <code>identity.document</code> e em
      <code>cert.brazilian</code>.
    </p>
  </section>

  <h2 id="erros">Erros que você pode ver</h2>
  <p>Toda falha de leitura é um <code>SignatureKitError</code> tipado no canal de erro. Os mais comuns ao ler certificados:</p>
  <ul>
    <li>
      <a href="/docs/errors#err-NO_CERTIFICATE"><code>signature-kit.NO_CERTIFICATE</code></a> — o material carregado não contém
      um certificado.
    </li>
    <li>
      <a href="/docs/errors#err-X509_PARSE_FAILED"><code>signature-kit.X509_PARSE_FAILED</code></a> — o DER não pôde ser
      parseado por <code>parseX509</code>.
    </li>
    <li>
      <a href="/docs/errors#err-PEM_EXTRACTION_FAILED"><code>signature-kit.PEM_EXTRACTION_FAILED</code></a> — falha ao extrair
      o PEM do certificado.
    </li>
  </ul>

  <div class="next-prev">
    <a href="/docs/signers">← A fronteira de assinatura</a>
    <a href="/docs/errors">Canal de erro tipado →</a>
  </div>
</DocsLayout>

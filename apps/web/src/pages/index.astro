---
import { ArrowRight, Sparkles } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/widgets/Header.astro";
import Footer from "../components/widgets/Footer.astro";
import CodePanel from "../components/CodePanel.astro";
import CodeTabs from "../components/CodeTabs.astro";
import InstallTabs from "../components/InstallTabs.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ErrorCatalog from "../components/ErrorCatalog.astro";
import RepoTree from "../components/RepoTree.astro";
import Button from "../components/starwind/Button.astro";
import {
  heroTabs,
  heroInstallSpec,
  runtimeTabs,
  signerAdapterType,
  formatTabs,
  providerTabs,
} from "../data/signature-kit";

const errorChips = [
  { code: "WRONG_PASSWORD" },
  { code: "NO_PRIVATE_KEY" },
  { code: "SIGN_FAILED" },
];
const claudeAsk = `https://claude.ai/new?q=${encodeURIComponent(
  "Sobre a biblioteca SignatureKit (assinatura digital Effect-native para TypeScript): ",
)}`;
---

<BaseLayout>
  <Header />

  <main>
    <!-- Hero — open editor -->
    <section class="sw-container grid items-center gap-12 py-16 lg:grid-cols-[0.92fr_1.08fr] lg:py-24">
      <div>
        <span class="font-mono text-xs text-muted-foreground">signature-kit — biblioteca de assinatura</span>
        <h1 class="track-display mt-5 text-4xl font-semibold leading-[1.05] tracking-tight text-foreground md:text-[2.95rem]">
          Assinatura digital Effect-native para TypeScript.
        </h1>
        <p class="mt-5 max-w-xl leading-7 text-muted-foreground">
          Uma fronteira assina bytes; XML, PDF e ICP-Brasil são pacotes. Carregue um assinador A1/PKCS#12 (e-CPF,
          e-CNPJ) uma vez e assine no navegador ou no servidor — com erro tipado e segredos <code
            class="font-mono text-foreground">Redacted</code
          >. DocuSign, Clicksign, Assinafy e ZapSign entram como signers remotos independentes.
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <Button variant="primary" size="lg" href="/docs/installation">
            Ler os conceitos <ArrowRight class="size-4" />
          </Button>
          <Button variant="outline" size="lg" href="/docs/quickstart">Primeiro uso</Button>
        </div>

        <div class="mt-5 max-w-md">
          <InstallTabs spec={heroInstallSpec} />
        </div>

        <div class="mt-6 flex flex-wrap items-center gap-2 font-mono text-xs">
          <span class="text-muted-foreground/55">// falha possível: SignatureKitError</span>
          {
            errorChips.map((c) => (
              <a
                href={`#err-${c.code}`}
                class="rounded-md border border-border bg-card px-2 py-0.5 text-muted-foreground transition hover:border-primary/40 hover:text-foreground"
              >
                {c.code}
              </a>
            ))
          }
        </div>
      </div>

      <div class="lg:pl-2">
        <CodeTabs tabs={heroTabs} />
      </div>
    </section>

    <!-- Onde roda — switcher, not marquee -->
    <section class="hairline-y bg-card/30">
      <div class="sw-container grid gap-8 py-16 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
        <div>
          <span class="font-mono text-xs text-muted-foreground">mesma API</span>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-foreground">O mesmo contrato em todo runtime.</h2>
          <p class="mt-3 text-sm leading-7 text-muted-foreground">
            Sem build por plataforma. O delta entre as abas é só a linha de runtime — o código de assinatura é idêntico.
          </p>
          <p class="mt-4 font-mono text-xs text-muted-foreground/70">// WebCrypto onde existe; node:crypto no servidor.</p>
        </div>
        <CodeTabs tabs={runtimeTabs} />
      </div>
    </section>

    <!-- 01 — A fronteira -->
    <section id="seam" class="sw-container py-20">
      <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <div>
          <span class="font-mono text-sm text-muted-foreground">01</span>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-foreground md:text-3xl">
            O core assina bytes. Só isso.
          </h2>
          <p class="mt-4 leading-7 text-muted-foreground">
            Um <code class="font-mono text-foreground">SignerAdapter</code> é a costura de capacidade: decide de onde vem
            o poder de assinar — A1 no navegador, <code class="font-mono text-foreground">node:crypto</code> no servidor,
            um provedor remoto. Nunca muta o documento.
          </p>
          <p class="mt-4 leading-7 text-muted-foreground">
            XML-DSig e PAdES são módulos sobre essa fronteira. A aplicação depende do contrato, não do backend.
          </p>
        </div>
        <CodePanel label={signerAdapterType.label} code={signerAdapterType.code} seam class="lg:sticky lg:top-24" />
      </div>
    </section>

    <!-- 02 — Formatos -->
    <section id="formats" class="hairline-t">
      <div class="sw-container grid gap-8 py-20 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <SectionHeader
          num="02"
          title="Formatos plugam na fronteira."
          lead="O formato prepara os bytes do documento. Quem assina continua sendo o serviço — a linha do layer não muda entre XML e PDF."
        />
        <CodeTabs tabs={formatTabs} />
      </div>
    </section>

    <!-- 03 — Catálogo de erros -->
    <section id="errors" class="hairline-t">
      <div class="sw-container py-20">
        <SectionHeader
          num="03"
          title="A falha é um valor, não uma exceção."
          lead="Um SignatureKitError, um catálogo de 15 códigos literais. Nenhum pacote inventa um modelo de erro paralelo."
          class="mb-10 max-w-2xl"
        />
        <ErrorCatalog />
      </div>
    </section>

    <!-- 04 — Pacotes -->
    <section id="packages" class="hairline-t">
      <div class="sw-container py-20">
        <SectionHeader
          num="04"
          title="Instale só o que usar."
          lead="O monorepo é a API: cada pacote tem uma responsabilidade. Escolha um nó para ver o que ele exporta."
          class="mb-10 max-w-2xl"
        />
        <RepoTree />
      </div>
    </section>

    <!-- 05 — Provedores -->
    <section id="providers" class="hairline-t">
      <div class="sw-container grid gap-8 py-20 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <SectionHeader
          num="05"
          title="Cada provedor é um pacote."
          lead="Config real e tipada por provedor — chaves diferentes, segredos Redacted. Cada pacote expõe sua própria create*SignatureRequest sem gateway normalizador."
        />
        <div class="space-y-4">
          <CodeTabs tabs={providerTabs} />
          <p class="font-mono text-xs leading-6 text-muted-foreground/70">
            // cada pacote remoto monta seu próprio protocolo e usa SignatureHttpClient.
            <br />// falhas remotas chegam como SignatureKitError com provider + status.
          </p>
        </div>
      </div>
    </section>

    <!-- Fechamento -->
    <section class="hairline-t">
      <div class="sw-container py-20 text-center">
        <h2 class="text-2xl font-semibold tracking-tight text-foreground md:text-3xl">
          Comece pelo A1. Adicione XML, PDF ou um provedor depois.
        </h2>
        <p class="mx-auto mt-4 max-w-xl leading-7 text-muted-foreground">
          O contrato da aplicação não muda quando você troca o backend de assinatura.
        </p>
        <div class="mx-auto mt-7 max-w-md text-left">
          <InstallTabs spec={heroInstallSpec} />
        </div>
        <div class="mt-6 flex items-center justify-center gap-5 text-sm">
          <a href="/docs/installation" class="font-medium text-primary-accent">Ler os conceitos →</a>
          <a
            href={claudeAsk}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 text-muted-foreground transition hover:text-foreground"
          >
            <Sparkles class="size-3.5" /> Perguntar à IA
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

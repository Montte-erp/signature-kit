---
import { Code } from "astro:components";
import { Check, Copy } from "@lucide/astro";

interface Props {
  spec: string;
  class?: string;
}

const { spec, class: className = "" } = Astro.props;
const managers = [
  { label: "bun", cmd: `bun add ${spec}` },
  { label: "pnpm", cmd: `pnpm add ${spec}` },
  { label: "npm", cmd: `npm i ${spec}` },
  { label: "yarn", cmd: `yarn add ${spec}` },
];
---

<div class={`sw-code group relative ${className}`} data-code-tabs>
  <div class="sw-code-tab justify-between">
    <div class="flex items-center">
      {
        managers.map((m, i) => (
          <button
            type="button"
            class="code-tab-btn -mb-px h-10 px-3 font-mono text-muted-foreground transition hover:text-foreground"
            data-tab={m.label}
            data-active={i === 0 ? "true" : "false"}
          >
            {m.label}
          </button>
        ))
      }
    </div>
    <button type="button" class="copy-btn shrink-0" data-copy={managers[0].cmd} aria-label="Copiar comando">
      <Copy class="size-3.5 [[data-copied=true]_&]:hidden" />
      <Check class="hidden size-3.5 [[data-copied=true]_&]:block" />
    </button>
  </div>
  {
    managers.map((m, i) => (
      <div data-tab-panel={m.label} hidden={i !== 0}>
        <Code code={m.cmd} lang="bash" theme="vesper" />
      </div>
    ))
  }
</div>

---
import { BookOpen, House } from "@lucide/astro";
import Logo from "../Logo.astro";
import Button from "../starwind/Button.astro";
import { landingNavigation, site } from "../../config";

interface Props {
  links?: { text: string; href: string }[];
  docs?: boolean;
  sidebarToggle?: boolean;
}

const { links = landingNavigation, docs = false, sidebarToggle = false } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-40 w-full border-b border-border bg-background/80 backdrop-blur-xl">
  <div class="sw-container flex h-14 items-center gap-4">
    <div class="flex items-center gap-3">
      {
        sidebarToggle && (
          <button
            type="button"
            data-sidebar-toggle
            class="grid size-8 place-items-center rounded-md border border-border text-muted-foreground lg:hidden"
            aria-label="Abrir navegação"
          >
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
              <path d="M2 4h11M2 7.5h11M2 11h11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            </svg>
          </button>
        )
      }
      <Logo />
      <span class="hidden rounded-full border border-border px-2 py-0.5 font-mono text-[10px] text-muted-foreground sm:inline">
        v{site.version}
      </span>
    </div>

    <nav class="ml-4 hidden items-center gap-1 md:flex" aria-label="Navegação principal">
      {
        links.map((link) => {
          const target = link.href.replace(/\/$/, "").replace(/^\/#.*/, "/");
          const active = path === target;
          return (
            <a
              class={`rounded-md px-3 py-1.5 font-mono text-sm transition ${active ? "text-foreground" : "text-muted-foreground hover:text-foreground"}`}
              href={link.href}
            >
              {link.text}
            </a>
          );
        })
      }
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <a
        href={site.github}
        target="_blank"
        rel="noreferrer"
        class="grid size-9 place-items-center rounded-md border border-border text-muted-foreground transition hover:border-primary/40 hover:text-foreground"
        aria-label="Repositório no GitHub"
      >
        <svg class="size-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
      </a>

      <Button variant={docs ? "ghost" : "primary"} size="sm" href={docs ? "/" : "/docs/installation"}>
        {docs ? <House class="size-3.5" /> : <BookOpen class="size-3.5" />}
        <span class="hidden sm:inline">{docs ? "Início" : "Documentação"}</span>
      </Button>
    </div>
  </div>
</header>

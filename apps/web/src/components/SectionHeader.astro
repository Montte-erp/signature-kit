---
interface Props {
  num?: string;
  title: string;
  lead?: string;
  class?: string;
}

const { num, title, lead, class: className = "" } = Astro.props;
---

<div class={className}>
  {num && <span class="font-mono text-sm text-muted-foreground">{num}</span>}
  <h2 class="mt-2 text-2xl font-semibold tracking-tight text-foreground md:text-3xl">{title}</h2>
  {lead && <p class="mt-3 max-w-xl leading-7 text-muted-foreground">{lead}</p>}
</div>

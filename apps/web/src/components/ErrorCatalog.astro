---
import { errorCatalog, errorShape } from "../data/signature-kit";
import CodePanel from "./CodePanel.astro";

interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<div class={`grid gap-5 lg:grid-cols-[0.92fr_1.08fr] lg:items-start ${className}`}>
  <CodePanel label={errorShape.label} code={errorShape.code} lang={errorShape.lang} class="lg:sticky lg:top-24" />

  <div class="overflow-hidden rounded-xl border border-border">
    <div
      class="grid grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] border-b border-border bg-card px-4 py-2.5 font-mono text-[10px] uppercase tracking-[0.18em] text-muted-foreground"
    >
      <span>código</span>
      <span>mensagem padrão</span>
    </div>
    {
      errorCatalog.map((e) => (
        <div
          id={e.code.replace("signature-kit.", "err-")}
          class="grid scroll-mt-24 grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] gap-3 border-b border-border px-4 py-2.5 last:border-0"
        >
          <code class="truncate font-mono text-xs">
            <span class="text-muted-foreground/50">signature-kit.</span>
            <span class="text-foreground">{e.code.replace("signature-kit.", "")}</span>
          </code>
          <span class="text-xs leading-6 text-muted-foreground">
            {e.message}
            {e.overridable && <span class="ml-1 text-muted-foreground/45">· editável</span>}
          </span>
        </div>
      ))
    }
  </div>
</div>

---
import { tv } from "tailwind-variants";

type ButtonVariant = "default" | "primary" | "secondary" | "outline" | "ghost" | "info" | "success" | "warning" | "error";
type ButtonSize = "sm" | "md" | "lg" | "icon" | "icon-sm" | "icon-lg";
type ButtonType = "button" | "submit" | "reset";

type Props = {
  href?: string;
  variant?: ButtonVariant;
  size?: ButtonSize;
  type?: ButtonType;
  class?: string;
  ariaLabel?: string;
};

const button = tv({
  base: "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border text-sm font-medium transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-outline disabled:pointer-events-none disabled:opacity-50",
  variants: {
    variant: {
      default: "border-border bg-card/80 text-card-foreground hover:border-primary/40 hover:bg-accent",
      primary: "border-foreground bg-foreground text-background hover:border-primary-accent hover:bg-primary-accent hover:text-info-foreground",
      secondary: "border-secondary bg-secondary text-secondary-foreground hover:bg-secondary-accent",
      outline: "border-border bg-transparent text-foreground hover:border-primary/40 hover:bg-primary/10",
      ghost: "border-transparent bg-transparent text-muted-foreground hover:bg-card hover:text-foreground",
      info: "border-info bg-info text-info-foreground",
      success: "border-success bg-success text-success-foreground",
      warning: "border-warning bg-warning text-warning-foreground",
      error: "border-error bg-error text-error-foreground",
    },
    size: {
      sm: "h-8 px-3 text-xs",
      md: "h-9 px-4",
      lg: "h-11 px-5 text-base",
      icon: "size-9 p-0",
      "icon-sm": "size-8 p-0",
      "icon-lg": "size-11 p-0",
    },
  },
  defaultVariants: {
    variant: "default",
    size: "md",
  },
});

const {
  href,
  variant = "default",
  size = "md",
  type = "button",
  class: className,
  ariaLabel,
} = Astro.props;

const classes = button({ variant, size, class: className });
---

{href ? (
  <a class={classes} href={href} aria-label={ariaLabel}>
    <slot />
  </a>
) : (
  <button class={classes} type={type} aria-label={ariaLabel}>
    <slot />
  </button>
)}

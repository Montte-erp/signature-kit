---
import { tv } from "tailwind-variants";

type CardSize = "default" | "sm";
type Props = {
  size?: CardSize;
  class?: string;
};

const card = tv({
  base: "rounded-lg border border-border bg-card/70 text-card-foreground backdrop-blur",
  variants: {
    size: {
      default: "p-6",
      sm: "p-4",
    },
  },
  defaultVariants: {
    size: "default",
  },
});

const { size = "default", class: className } = Astro.props;
---

<article class={card({ size, class: className })}>
  <slot />
</article>

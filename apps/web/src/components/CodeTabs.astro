---
import { Code } from "astro:components";
import { Check, Copy } from "@lucide/astro";
import type { Snippet } from "../data/signature-kit";

interface Props {
  tabs: Snippet[];
  class?: string;
  seam?: boolean;
}

const { tabs, class: className = "", seam = false } = Astro.props;
const items = tabs.map((t) => ({ ...t, code: t.code.trim(), lang: t.lang ?? "ts" }));
---

<div class={`sw-code group relative ${seam ? "seam-frame" : ""} ${className}`} data-code-tabs>
  <div class="sw-code-tab justify-between gap-4 overflow-x-auto">
    <div class="flex items-center">
      {
        items.map((tab, i) => (
          <button
            type="button"
            class="code-tab-btn -mb-px h-10 whitespace-nowrap border-b-2 border-transparent px-3 font-mono text-muted-foreground transition hover:text-foreground"
            data-tab={tab.label}
            data-active={i === 0 ? "true" : "false"}
          >
            {tab.label}
          </button>
        ))
      }
    </div>
    <button type="button" class="copy-btn shrink-0" data-copy={items[0]?.code} aria-label="Copiar">
      <Copy class="size-3.5 [[data-copied=true]_&]:hidden" />
      <Check class="hidden size-3.5 [[data-copied=true]_&]:block" />
    </button>
  </div>
  {
    items.map((tab, i) => (
      <div data-tab-panel={tab.label} hidden={i !== 0}>
        <Code code={tab.code} lang={tab.lang} theme="vesper" />
      </div>
    ))
  }
</div>

---
import { Code } from "astro:components";
import { Check, Copy, Terminal } from "@lucide/astro";

interface Props {
  label?: string;
  code?: string;
  lang?: string;
  kind?: "file" | "terminal";
  seam?: boolean;
  class?: string;
}

const { label, code = "", lang, kind = "file", seam = false, class: className = "" } = Astro.props;
const trimmed = code.trim();
const language = lang ?? (kind === "terminal" ? "bash" : "ts");
const title = label ?? (kind === "terminal" ? "Terminal" : "código");
---

<div class={`sw-code group relative ${seam ? "seam-frame" : ""} ${className}`}>
  <div class="sw-code-tab justify-between">
    <span class="inline-flex items-center gap-2">
      {kind === "terminal" && <Terminal class="size-3.5 text-muted-foreground" />}
      <span class={kind === "terminal" ? "text-[10px] uppercase tracking-[0.18em]" : "text-foreground"}>{title}</span>
    </span>
    <button
      type="button"
      class="copy-btn shrink-0 opacity-0 transition group-hover:opacity-100 focus-visible:opacity-100"
      data-copy={trimmed}
      aria-label="Copiar"
    >
      <Copy class="size-3.5 [[data-copied=true]_&]:hidden" />
      <Check class="hidden size-3.5 [[data-copied=true]_&]:block" />
    </button>
  </div>
  <Code code={trimmed} lang={language as any} theme="vesper" />
</div>

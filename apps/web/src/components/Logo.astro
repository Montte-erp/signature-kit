---
import { Signature } from "@lucide/astro";
const { label = "signature-kit" } = Astro.props;
---

<a
  class="inline-flex items-center gap-2 text-sm font-semibold tracking-tight text-foreground"
  href="/"
  aria-label="Início do SignatureKit"
>
  <span class="grid size-7 place-items-center rounded-lg bg-primary text-primary-foreground">
    <Signature class="size-4" strokeWidth={2.4} />
  </span>
  <span class="font-mono">{label}</span>
</a>

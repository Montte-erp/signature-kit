{
  "name": "@signature-kit/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./paraglide --strategy baseLocale",
    "dev": "bun run paraglide && next dev --hostname 0.0.0.0 --port ${PORT:-3001}",
    "build": "bun run --cwd ../.. build --force && bun run paraglide && next build",
    "start": "next start --hostname 0.0.0.0 --port ${PORT:-3001}",
    "postinstall": "fumadocs-mdx && paraglide-js compile --project ./project.inlang --outdir ./paraglide --strategy baseLocale",
    "types:check": "fumadocs-mdx && next typegen && bun run paraglide && tsc --noEmit"
  },
  "dependencies": {
    "@cantoo/pdf-lib": "2.7.1",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-pdf/renderer": "4.5.1",
    "@signature-kit/a1": "workspace:*",
    "@signature-kit/pdf": "workspace:*",
    "@signature-kit/core": "workspace:*",
    "@tanstack/react-form": "0.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "4.0.0-beta.86",
    "fumadocs-core": "^16.7.9",
    "fumadocs-mdx": "^14.2.8",
    "fumadocs-ui": "^16.7.9",
    "lucide-react": "^1.20.0",
    "mermaid": "^11.16.0",
    "motion": "^12.34.2",
    "next": "16.2.9",
    "pdfjs-dist": "^4.10.38",
    "posthog-js": "^1.396.2",
    "posthog-node": "^5.39.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "simple-icons": "^15.18.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "2.20.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "latest"
  }
}

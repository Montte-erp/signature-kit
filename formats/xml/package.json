{
  "name": "@signature-kit/xml",
  "version": "0.2.0",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./sign": {
      "types": "./dist/sign.d.ts",
      "import": "./dist/sign.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@peculiar/x509": "2.0.0",
    "@signature-kit/core": "^0.2.0",
    "@signature-kit/crypto": "^0.2.0",
    "@xmldom/xmldom": "^0.9.8",
    "effect": "4.0.0-beta.86",
    "reflect-metadata": "^0.2.2",
    "xml-core": "^1.2.5",
    "xmldsigjs": "2.8.7"
  },
  "devDependencies": {
    "@signature-kit/a1": "^0.2.0",
    "xml-crypto": "6.1.2"
  },
  "nx": {
    "targets": {
      "npm-pack": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm pack --dry-run --json",
          "cwd": "{projectRoot}"
        }
      },
      "npm-publish": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm publish --access public",
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}

{
  "name": "@signature-kit/pdf",
  "version": "0.2.0",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./builder": {
      "types": "./dist/builder.d.ts",
      "import": "./dist/builder.js"
    },
    "./builder-store": {
      "types": "./dist/builder-store.d.ts",
      "import": "./dist/builder-store.js"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "import": "./dist/workflow.js"
    },
    "./sign": {
      "types": "./dist/sign.d.ts",
      "import": "./dist/sign.js"
    },
    "./stamp": {
      "types": "./dist/stamp.d.ts",
      "import": "./dist/stamp.js"
    },
    "./liteparse-browser": {
      "types": "./dist/liteparse-browser.d.ts",
      "import": "./dist/liteparse-browser.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cantoo/pdf-lib": "2.7.1",
    "@llamaindex/liteparse-wasm": "^2.4.0",
    "@signature-kit/cms": "^0.2.0",
    "@signature-kit/core": "^0.2.0",
    "effect": "4.0.0-beta.86"
  },
  "devDependencies": {
    "@signature-kit/a1": "^0.2.0"
  },
  "nx": {
    "targets": {
      "npm-pack": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm pack --dry-run --json",
          "cwd": "{projectRoot}"
        }
      },
      "npm-publish": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm publish --access public",
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}

{
  "name": "@signature-kit/pdf",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./builder": {
      "types": "./dist/builder.d.ts",
      "import": "./dist/builder.js"
    },
    "./builder-store": {
      "types": "./dist/builder-store.d.ts",
      "import": "./dist/builder-store.js"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "import": "./dist/workflow.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./sign": {
      "types": "./dist/sign.d.ts",
      "import": "./dist/sign.js"
    },
    "./stamp": {
      "types": "./dist/stamp.d.ts",
      "import": "./dist/stamp.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cantoo/pdf-lib": "2.7.1",
    "@signature-kit/cms": "workspace:*",
    "@signature-kit/core": "workspace:*",
    "effect": "4.0.0-beta.86"
  },
  "devDependencies": {
    "@signature-kit/a1": "workspace:*"
  }
}

{
  "extends": "./tooling/typescript/base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "rootDir": ".",
    "types": ["bun"]
  },
  "include": [
    "core/**/__tests__/**/*.ts",
    "formats/**/__tests__/**/*.ts",
    "shared/**/__tests__/**/*.ts",
    "signers/**/__tests__/**/*.ts",
    "tooling/integration-tests/**/*.ts",
    "tooling/static-checks/__tests__/**/*.ts",
    "tooling/testing/**/*.ts",
    "tooling/vitest/**/*.ts"
  ]
}

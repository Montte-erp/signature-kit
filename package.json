{
  "name": "signature-kit",
  "private": true,
  "workspaces": [
    "apps/*",
    "core/*",
    "signers/*",
    "formats/*",
    "shared/*",
    "tooling/*"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "typecheck:docs": "bun --cwd apps/docs types:check",
    "test": "vitest run",
    "test:validar-iti": "SIGNATURE_KIT_ITI_VALIDATE=1 vitest run formats/pdf/__tests__/validar-iti.integration.test.ts formats/pdf/__tests__/pdf-a1-validar-iti.integration.test.ts",
    "test:integration:server": "bun --cwd tooling/integration-tests test:server",
    "test:integration:browser": "vitest run --config tooling/vitest/browser.config.ts signers/a1/__tests__/a1.browser.test.ts formats/pdf/__tests__/pdf-a1.browser.test.ts",
    "test:e2e:pdf-a1": "vitest run --config tooling/vitest/browser.config.ts formats/pdf/__tests__/pdf-a1.browser.test.ts",
    "test:performance": "vitest run core/certificates/__tests__/certificates.performance.test.ts signers/a1/__tests__/a1.performance.test.ts formats/pdf/__tests__/pdf.performance.test.ts",
    "test:live:remote-signers": "SIGNATURE_KIT_LIVE_REMOTE_SIGNERS=1 vitest run signers/clicksign/__tests__/clicksign.live.test.ts signers/assinafy/__tests__/assinafy.live.test.ts signers/zapsign/__tests__/zapsign.live.test.ts signers/documenso/__tests__/documenso.live.test.ts signers/docuseal/__tests__/docuseal.live.test.ts",
    "site:dev": "bun --cwd apps/docs dev",
    "site:build": "bun --cwd apps/docs build",
    "check:declarative-errors": "bun tooling/static-checks/check-declarative-errors.ts",
    "lint": "oxlint -c tooling/oxc/base.json core signers formats shared tooling --deny-warnings",
    "lint:docs": "oxlint -c tooling/oxc/react.json apps/docs/app apps/docs/components apps/docs/lib --deny-warnings",
    "format": "oxfmt -c tooling/oxc/oxfmt.json --write core signers formats shared tooling '!**/.cache/**' '!**/node_modules/**' '!**/dist/**' '!**/*.d.ts' '!**/*.tsbuildinfo'",
    "format:check": "oxfmt -c tooling/oxc/oxfmt.json --check core signers formats shared tooling '!**/.cache/**' '!**/node_modules/**' '!**/dist/**' '!**/*.d.ts' '!**/*.tsbuildinfo'",
    "check:static": "bun run check:declarative-errors && bun run lint && bun run lint:docs && bun run format:check",
    "check": "bun run check:static && bun run typecheck && bun run typecheck:test && bun run typecheck:docs",
    "pack:npm": "nx run-many --target=npm-pack --projects=@signature-kit/asn1,@signature-kit/core,@signature-kit/crypto,@signature-kit/cms,@signature-kit/certificates,@signature-kit/a1,@signature-kit/assinafy,@signature-kit/clicksign,@signature-kit/documenso,@signature-kit/docuseal,@signature-kit/zapsign,@signature-kit/xml,@signature-kit/pdf --parallel=1",
    "publish:npm": "nx run-many --target=npm-publish --projects=@signature-kit/asn1,@signature-kit/core,@signature-kit/crypto,@signature-kit/cms,@signature-kit/certificates,@signature-kit/a1,@signature-kit/assinafy,@signature-kit/clicksign,@signature-kit/documenso,@signature-kit/docuseal,@signature-kit/zapsign,@signature-kit/xml,@signature-kit/pdf --parallel=1"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.86",
    "@effect/vitest": "4.0.0-beta.86",
    "@types/bun": "latest",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "^4.1.9",
    "effect": "4.0.0-beta.86",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "playwright": "^1.61.0",
    "typescript": "latest",
    "vitest": "^4.0.0",
    "nx": "23.0.1"
  },
  "packageManager": "bun@1.3.14"
}

{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "outDir": "${configDir}/dist",
    "rootDir": "${configDir}/src",
    "emitDeclarationOnly": false,
    "lib": ["ES2022", "DOM"]
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/__tests__/**"]
}

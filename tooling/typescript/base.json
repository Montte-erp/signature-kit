{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "types": ["bun"],
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "incremental": true,
    "isolatedDeclarations": false,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "emitDeclarationOnly": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "tsBuildInfoFile": "${configDir}/.cache/tsbuildinfo.json",
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "../..",
    "paths": {
      "@signature-kit/a1/config": ["signers/a1/src/config.ts"],
      "@signature-kit/a1/signer": ["signers/a1/src/create-a1-signer-adapter.ts"],
      "@signature-kit/a1/web-crypto": ["signers/a1/src/web-crypto.ts"],
      "@signature-kit/asn1": ["shared/asn1/src/config.ts"],
      "@signature-kit/assinafy": ["signers/assinafy/src/index.ts"],
      "@signature-kit/certificates": ["core/certificates/src/index.ts"],
      "@signature-kit/clicksign": ["signers/clicksign/src/index.ts"],
      "@signature-kit/cms/attributes": ["shared/cms/src/attributes.ts"],
      "@signature-kit/cms/config": ["shared/cms/src/config.ts"],
      "@signature-kit/cms/engine": ["shared/cms/src/engine.ts"],
      "@signature-kit/cms/icp-brasil": ["shared/cms/src/icp-brasil.ts"],
      "@signature-kit/cms/sign": ["shared/cms/src/sign.ts"],
      "@signature-kit/cms/timestamp": ["shared/cms/src/timestamp.ts"],
      "@signature-kit/cms/verify": ["shared/cms/src/verify.ts"],
      "@signature-kit/core/config": ["core/core/src/config.ts"],
      "@signature-kit/core/http": ["core/core/src/http.ts"],
      "@signature-kit/core/runtime": ["core/core/src/runtime.ts"],
      "@signature-kit/core/signatures": ["core/core/src/signatures.ts"],
      "@signature-kit/crypto/base64": ["shared/crypto/src/base64.ts"],
      "@signature-kit/crypto/config": ["shared/crypto/src/config.ts"],
      "@signature-kit/crypto/hash": ["shared/crypto/src/hash.ts"],
      "@signature-kit/crypto/pem": ["shared/crypto/src/pem.ts"],
      "@signature-kit/crypto/pkcs12": ["shared/crypto/src/pkcs12.ts"],
      "@signature-kit/docusign": ["signers/docusign/src/index.ts"],
      "@signature-kit/zapsign": ["signers/zapsign/src/index.ts"],
      "@signature-kit/pdf/config": ["formats/pdf/src/config.ts"],
      "@signature-kit/pdf/sign": ["formats/pdf/src/sign.ts"],
      "@signature-kit/pdf/verify": ["formats/pdf/src/verify.ts"],
      "@signature-kit/xml/config": ["formats/xml/src/config.ts"],
      "@signature-kit/xml/sign": ["formats/xml/src/sign.ts"],
      "@signature-kit/xml/verify": ["formats/xml/src/verify.ts"]
    }
  },
  "display": "Default"
}

{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "types": ["bun"],
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "incremental": true,
    "isolatedDeclarations": false,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "emitDeclarationOnly": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "tsBuildInfoFile": "${configDir}/.cache/tsbuildinfo.json",
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "../..",
    "paths": {
      "@signature-kit/asn1": ["shared/asn1/src/index.ts"],
      "@signature-kit/crypto": ["shared/crypto/src/index.ts"],
      "@signature-kit/cms": ["shared/cms/src/index.ts"],
      "@signature-kit/contracts": ["core/contracts/src/index.ts"],
      "@signature-kit/core": ["core/core/src/index.ts"],
      "@signature-kit/x509": ["core/x509/src/index.ts"],
      "@signature-kit/a1": ["signers/a1/src/index.ts"],
      "@signature-kit/signature-gateway": ["integrations/signature-gateway/src/index.ts"],
      "@signature-kit/docusign": ["integrations/docusign/src/index.ts"],
      "@signature-kit/dropbox-sign": ["integrations/dropbox-sign/src/index.ts"],
      "@signature-kit/adobe-sign": ["integrations/adobe-sign/src/index.ts"],
      "@signature-kit/clicksign": ["integrations/clicksign/src/index.ts"],
      "@signature-kit/xml": ["formats/xml/src/index.ts"],
      "@signature-kit/pdf": ["formats/pdf/src/index.ts"]
    }
  },
  "display": "Default"
}
